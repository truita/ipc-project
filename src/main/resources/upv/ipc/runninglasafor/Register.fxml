<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>

<VBox alignment="CENTER" prefHeight="559.0" prefWidth="569.0" spacing="25.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="upv.ipc.runninglasafor.PrimaryController">
   <children>
      <VBox alignment="CENTER">
         <children>
            <Label text="Register">
               <font>
                  <Font size="24.0" />
               </font>
            </Label>
            <Line endX="100.0" startX="-100.0" />
         </children>
      </VBox>
      <VBox alignment="CENTER" maxWidth="200.0" spacing="8.0">
         <children>
            <VBox>
               <children>
                  <Label text="Email*" />
                  <TextField maxWidth="200.0" />
               </children>
            </VBox>
            <VBox>
               <children>
                  <Label text="Password*" />
                  <TextField maxWidth="200.0" />
               </children>
            </VBox>
            <VBox>
               <children>
                  <Label text="Birth date*" />
                  <DatePicker prefWidth="100.0" />
               </children>
            </VBox>
         </children>
      </VBox>
      <VBox alignment="CENTER" maxWidth="200.0" spacing="8.0">
         <children>
            <VBox>
               <children>
                  <Label text="Nickname*" />
                  <TextField maxWidth="200.0" />
               </children>
            </VBox>
            <VBox>
               <children>
                  <Label text="Avatar" />
                  <HBox spacing="10.0">
                     <children>
                        <Button mnemonicParsing="false" text="Browse" />
                        <Label prefHeight="25.0" prefWidth="89.0" text="No file selected" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
      <VBox alignment="CENTER" spacing="3.0">
         <children>
            <Button fx:id="primaryButton" onAction="#switchToSecondary" prefWidth="200.0" text="Register" />
            <TextFlow maxWidth="200.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Already have an account? " />
                  <Text fill="#adc2fc" strokeType="OUTSIDE" strokeWidth="0.0" text="Log in" />
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text=" instead." />
               </children>
            </TextFlow>
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
