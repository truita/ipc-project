<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>

<VBox alignment="CENTER" prefHeight="559.0" prefWidth="569.0" spacing="25.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="upv.ipc.runninglasafor.controllers.LoginController">
   <children>
      <VBox alignment="CENTER">
         <children>
            <Label text="Log in">
               <font>
                  <Font size="24.0" />
               </font>
            </Label>
            <Line endX="100.0" startX="-100.0" />
         </children>
      </VBox>
      <VBox alignment="CENTER" maxWidth="200.0" spacing="8.0">
         <children>
            <VBox>
               <children>
                  <Label fx:id="nicknameLabel" text="Nickname" />
                  <TextField fx:id="nicknameTextField" maxWidth="200.0" />
               </children>
            </VBox>
            <VBox>
               <children>
                  <Label fx:id="passwordLabel" text="Password" />
                  <PasswordField fx:id="passwordField" />
               </children>
            </VBox>
         </children>
      </VBox>
      <VBox alignment="CENTER" spacing="3.0">
         <children>
            <Label fx:id="incorrectLoginError" text="Incorrect username or password" textFill="#d1242f" />
            <Label fx:id="missingFieldError" layoutX="183.0" layoutY="10.0" text="There are missing fields" textFill="#d1242f" />
            <Button fx:id="primaryButton" onAction="#login" prefWidth="200.0" text="Log in" />
            <TextFlow maxWidth="200.0" textAlignment="CENTER">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Don't have an account? " />
                  <Hyperlink onAction="#switchToRegister" text="Register" />
               </children>
            </TextFlow>
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
