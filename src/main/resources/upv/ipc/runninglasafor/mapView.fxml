<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Polyline?>
<?import javafx.scene.text.Font?>

<StackPane alignment="BOTTOM_RIGHT" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="upv.ipc.runninglasafor.controllers.MapController">
   <children>
      <ScrollPane fx:id="scrollPane" pannable="true">
         <content>
            <Group>
               <children>
                  <Pane fx:id="zoomPane">
                     <children>
                        <ImageView fx:id="imageView" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@maps/calderona.jpg" />
                           </image>
                        </ImageView>
                        <Polyline fx:id="activityTrace" disable="true" fill="TRANSPARENT" points="" stroke="#1680eb" strokeType="INSIDE" strokeWidth="3.0" />
                     </children>
                  </Pane>
               </children>
            </Group>
         </content>
         <cursor>
            <Cursor fx:constant="DEFAULT" />
         </cursor>
      </ScrollPane>
      <VBox fx:id="zoomButtons" alignment="BOTTOM_RIGHT" maxHeight="0.0" maxWidth="0.0">
         <children>
            <Button minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#zoomIn" prefHeight="30.0" prefWidth="30.0" text="+">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
               <font>
                  <Font name="Font Awesome 7 Free Solid" size="13.0" />
               </font>
            </Button>
            <Button minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#zoomOut" prefHeight="30.0" prefWidth="30.0" text="">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
               <font>
                  <Font name="Font Awesome 7 Free Solid" size="13.0" />
               </font>
            </Button>
         </children>
         <StackPane.margin>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </StackPane.margin>
      </VBox>
   </children>
</StackPane>
