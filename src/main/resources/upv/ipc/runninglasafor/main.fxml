<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<SplitPane dividerPositions="0.3" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="1000.0" stylesheets="@/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="upv.ipc.runninglasafor.controllers.MainController">
  <items>
      <VBox>
         <children>
            <ButtonBar buttonMinWidth="0.0" buttonOrder="U">
               <buttons>
                <Button mnemonicParsing="false" text="" textAlignment="CENTER">
                     <font>
                        <Font name="Font Awesome 7 Free Solid" size="13.0" />
                     </font></Button>
                  <Button mnemonicParsing="false" text="" textAlignment="CENTER">
                     <font>
                        <Font name="Font Awesome 7 Free Solid" size="13.0" />
                     </font>
                  </Button>
                  <Button mnemonicParsing="false" text="" textAlignment="CENTER">
                     <font>
                        <Font name="Font Awesome 7 Free Solid" size="13.0" />
                     </font>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#editUser" text="" textAlignment="CENTER">
                     <font>
                        <Font name="Font Awesome 7 Free Solid" size="13.0" />
                     </font>
                  </Button>
               </buttons>
            </ButtonBar>
            <ListView fx:id="activityList" fixedCellSize="50.0" minWidth="-Infinity" prefWidth="250.0" VBox.vgrow="ALWAYS" />
         </children>
      </VBox>
      <VBox>
         <children>
            <ButtonBar buttonMinWidth="0.0" buttonOrder="+U">
               <buttons>
                  <Button mnemonicParsing="false" text="" textAlignment="CENTER">
                     <font>
                        <Font name="Font Awesome 7 Free Solid" size="13.0" />
                     </font>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#toggleSpeed" text="" textAlignment="CENTER">
                     <font>
                        <Font name="Font Awesome 7 Free Solid" size="13.0" />
                     </font>
                  </Button>
               </buttons>
            </ButtonBar>
            <fx:include fx:id="map" alignment="BOTTOM_RIGHT" source="mapView.fxml" VBox.vgrow="ALWAYS" />
         </children>
      </VBox>
  </items>
</SplitPane>
