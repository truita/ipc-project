<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<SplitPane dividerPositions="0.3" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="upv.ipc.runninglasafor.MainController">
  <items>
      <ListView />
      <StackPane alignment="BOTTOM_RIGHT" prefHeight="150.0" prefWidth="200.0">
         <children>
            <ScrollPane fx:id="scrollPane">
               <content>
                  <Group>
                     <children>
                        <Pane fx:id="zoomPane">
                           <children>
                              <ImageView pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@maps/upv.jpg" />
                                 </image>
                              </ImageView>
                           </children>
                        </Pane>
                     </children>
                  </Group>
               </content>
            </ScrollPane>
            <VBox fx:id="zoomButtons" alignment="BOTTOM_RIGHT" maxHeight="0.0" maxWidth="0.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#zoomIn" text="+" />
                  <Button mnemonicParsing="false" onAction="#zoomOut" text="-" />
               </children>
               <StackPane.margin>
                  <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
               </StackPane.margin>
            </VBox>
         </children>
      </StackPane>
  </items>
</SplitPane>
